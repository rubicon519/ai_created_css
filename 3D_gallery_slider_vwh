<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Gallery Slider</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&family=Montserrat:wght@300;400&display=swap');

  /* ============================================================
     기본 리셋 및 레이아웃
  ============================================================ */
  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    background: #fff;
    color: #2a2018;
    font-family: 'Montserrat', sans-serif;
    min-height: 100dvh;         /* dvh: 모바일 주소창 대응 동적 뷰포트 */
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-start;
    overflow-x: hidden;         /* 화면 밖 슬라이드 카드 가로 스크롤 방지 */
    user-select: none;
  }

  /* ============================================================
     상단 텍스트 헤더
  ============================================================ */
  .gallery-header {
    text-align: center;
    padding-top: 4.17vw;          /* 60px → 4.17vw */
    position: relative;
    z-index: 10;
  }
  .gallery-label {
    font-size: 0.76vw;            /* 11px → 0.76vw */
    letter-spacing: 0.25em;
    color: #9a8c7a;
    margin-bottom: 1.11vw;        /* 16px → 1.11vw */
    display: block;
  }
  .gallery-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 3.8vw;             /* clamp 제거 → 3.8vw */
    font-weight: 400;
    line-height: 1.3;
    color: #2a1f10;
    max-width: 41.67vw;           /* 600px → 41.67vw */
  }

  /* ============================================================
     네비게이션 버튼 (텍스트 바로 아래 중앙 배치)
  ============================================================ */
  .nav-buttons {
    display: flex;
    gap: 0.42vw;                  /* 6px → 0.42vw */
    margin-top: 1.39vw;           /* 20px → 1.39vw */
    justify-content: center;
    position: relative;
    z-index: 10;
  }
  .nav-btn {
    width: 2.64vw; height: 2.36vw; /* 38px/34px → vw */
    border: 1px solid #ddd;
    background: #fff;
    color: #666;
    cursor: pointer;
    font-size: 0.9vw;             /* 13px → 0.9vw */
    display: flex; align-items: center; justify-content: center;
    transition: all 0.2s ease;
    border-radius: 2px;
  }
  .nav-btn:hover { background: #f7f4f0; border-color: #bbb; }

  /* ============================================================
     슬라이더 씬 (3D 원근감 컨테이너)
     기준 해상도 1440px 기준으로 px → vw 변환
     perspective: 보는 사람의 눈 거리. 값이 작을수록 원근 왜곡 강함
     perspective-origin: 소실점 위치. 50% 50% = 정중앙 기준
     overflow: visible — 양옆 카드가 화면 밖으로 나가도 보이도록
  ============================================================ */
  .slider-wrap {
    margin-top: 1.67vw;           /* 24px → 1.67vw */
    position: relative;
    width: 100vw;
    height: 27.1vw;               /* 390px → 27.1vw */
    overflow: visible;
    perspective: 62.5vw;          /* 900px → 62.5vw */
    perspective-origin: 50% 50%;
  }

  .slider-stage {
    position: absolute;
    width: 100vw;
    height: 100%;
    transform-style: preserve-3d;
    overflow: visible;
  }

  .slide {
    position: absolute;
    border-radius: 2px;
    overflow: hidden;
    cursor: pointer;
    transition:
      transform 0.75s cubic-bezier(0.22, 0.61, 0.36, 1),
      opacity   0.75s ease,
      filter    0.75s ease,
      width     0.75s cubic-bezier(0.22, 0.61, 0.36, 1),
      height    0.75s cubic-bezier(0.22, 0.61, 0.36, 1),
      left      0.75s cubic-bezier(0.22, 0.61, 0.36, 1),
      top       0.75s cubic-bezier(0.22, 0.61, 0.36, 1);
    transform-style: preserve-3d;
    box-shadow: 0 0.28vw 1.67vw rgba(0,0,0,0.10); /* 4px/24px → vw */
  }

  /* ============================================================
     ★★★ 포지션별 카드 크기 & 기울기 ★★★
     기준 해상도 1440px 기준 vw 변환:
       가로: 22vw (모든 포지션 동일)
       3번 세로: 300px → 20.83vw
       2/4번 세로: 318px → 22.08vw
       1/5번 세로: 382px → 26.53vw
       left 보정: 11vw (가로 절반)
       top 보정:
         3번: 10.42vw (20.83 / 2)
         2/4번: 11.04vw (22.08 / 2)
         1/5번: 13.26vw (26.53 / 2)
  ============================================================ */

  /* 3번 포지션 — 정면 중앙 */
  .slide.active {
    width: 22vw;                  /* ★ 가로 기준 */
    height: 20.83vw;              /* ★ 300px → 20.83vw */
    left: calc(50% - 11vw);      /* 22vw / 2 */
    top:  calc(50% - 10.42vw);   /* 20.83vw / 2 */
    transform: translateX(0) translateZ(0) rotateY(0deg);
    opacity: 1;
    filter: brightness(1);
    z-index: 5;
  }

  /* 2번 포지션 */
  .slide.prev {
    width: 22vw;                  /* ★ 가로: 3번과 동일 */
    height: 22.08vw;              /* ★ 318px → 22.08vw */
    left: calc(50% - 11vw);
    top:  calc(50% - 11.04vw);   /* 22.08vw / 2 */
    transform: translateX(-22.5vw) translateZ(0) rotateY(21deg);
    opacity: 1;
    filter: brightness(0.92);
    z-index: 4;
  }

  /* 4번 포지션 */
  .slide.next {
    width: 22vw;
    height: 22.08vw;
    left: calc(50% - 11vw);
    top:  calc(50% - 11.04vw);
    transform: translateX(22.5vw) translateZ(0) rotateY(-21deg);
    opacity: 1;
    filter: brightness(0.92);
    z-index: 4;
  }

  /* 1번 포지션 */
  .slide.prev2 {
    width: 22vw;                  /* ★ 가로: 3번과 동일 */
    height: 26.53vw;              /* ★ 382px → 26.53vw */
    left: calc(50% - 11vw);
    top:  calc(50% - 13.26vw);   /* 26.53vw / 2 */
    transform: translateX(-48.5vw) translateZ(-2.08vw) rotateY(38deg); /* 30px → 2.08vw */
    opacity: 0.85;
    filter: brightness(0.78);
    z-index: 3;
  }

  /* 5번 포지션 */
  .slide.next2 {
    width: 22vw;
    height: 26.53vw;
    left: calc(50% - 11vw);
    top:  calc(50% - 13.26vw);
    transform: translateX(48.5vw) translateZ(-2.08vw) rotateY(-38deg);
    opacity: 0.85;
    filter: brightness(0.78);
    z-index: 3;
  }

  /* 0번 — 왼쪽 화면 밖 대기 */
  .slide.prev3 {
    width: 22vw;
    height: 26.53vw;
    left: calc(50% - 11vw);
    top:  calc(50% - 13.26vw);
    transform: translateX(-91vw) translateZ(-2.08vw) rotateY(38deg);
    opacity: 0;
    filter: brightness(0.78);
    pointer-events: none;
    z-index: 2;
  }

  /* 6번 — 오른쪽 화면 밖 대기 */
  .slide.next3 {
    width: 22vw;
    height: 26.53vw;
    left: calc(50% - 11vw);
    top:  calc(50% - 13.26vw);
    transform: translateX(91vw) translateZ(-2.08vw) rotateY(-38deg);
    opacity: 0;
    filter: brightness(0.78);
    pointer-events: none;
    z-index: 2;
  }

  /* 완전 숨김 */
  .slide.hidden {
    width: 22vw;
    height: 20.83vw;
    left: calc(50% - 11vw);
    top:  calc(50% - 10.42vw);
    opacity: 0;
    pointer-events: none;
    transform: translateX(0) translateZ(-13.89vw) scale(0.7); /* 200px → 13.89vw */
    z-index: 0;
    transition: none;
  }

  /* ============================================================
     카드 내부 구성
  ============================================================ */
  /* 이미지/배경을 담는 컨테이너 */
  .slide-inner {
    width: 100%; height: 100%;
    overflow: hidden;
    position: relative;
  }
  /* 하단 그라디언트 오버레이 (텍스트 가독성용) */
  .slide-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(180deg, transparent 55%, rgba(0,0,0,0.22) 100%);
    z-index: 2; pointer-events: none;
  }

  /* ============================================================
     하단 도트 인디케이터
  ============================================================ */
  .dots-wrap {
    margin-top: 1.39vw;           /* 20px → 1.39vw */
    display: flex; gap: 0.42vw;   /* 6px → 0.42vw */
    justify-content: center;
    position: relative; z-index: 10;
  }
  .dot {
    width: 0.35vw; height: 0.35vw; /* 5px → 0.35vw */
    border-radius: 50%;
    background: #ddd; cursor: pointer;
    transition: all 0.3s ease;
  }
  .dot.active { background: #8a7a65; width: 1.25vw; border-radius: 3px; } /* 18px → 1.25vw */
</style>
</head>
<body>

<div class="gallery-header">
  <span class="gallery-label">About Resort</span>
  <div class="gallery-title">Relaxing moments and<br>breathtaking views, captured for you.</div>
</div>

<div class="nav-buttons">
  <button class="nav-btn" id="prevBtn">&#8249;</button>
  <button class="nav-btn" id="nextBtn">&#8250;</button>
</div>

<div class="slider-wrap">
  <div class="slider-stage" id="stage"></div>
</div>

<div class="dots-wrap" id="dots"></div>

<script>
  /* ============================================================
     이미지 데이터
     실제 사용 시 bg 대신 이미지 URL로 교체
     예: { bg: "url('images/room1.jpg')" }
  ============================================================ */
  const artworks = [
    { bg:"linear-gradient(160deg,#c8b89a,#9a8060,#5a4030)" },
    { bg:"linear-gradient(160deg,#8aacb8,#5a7a8a,#2a4a5a)" },
    { bg:"linear-gradient(160deg,#b09aba,#7a6a8a,#3a2a4a)" },
    { bg:"linear-gradient(160deg,#8ab898,#5a8a68,#2a4a38)" },
    { bg:"linear-gradient(160deg,#8a9ab8,#5a6a8a,#2a3050)" },
    { bg:"linear-gradient(160deg,#a8c0a0,#6a9070,#2a5038)" },
    { bg:"linear-gradient(160deg,#c09090,#8a5050,#4a2020)" },
  ];

  let current = 0;           /* 현재 중앙(active)에 표시되는 이미지 인덱스 */
  const total = artworks.length;
  const stage = document.getElementById('stage');
  const dotsEl = document.getElementById('dots');
  let isAnimating = false;   /* 전환 중 중복 입력 방지 플래그 */

  /* ============================================================
     슬라이드 DOM 및 도트 생성
  ============================================================ */
  artworks.forEach((art, i) => {
    const slide = document.createElement('div');
    slide.className = 'slide hidden'; /* 초기에는 모두 hidden */
    slide.innerHTML = `
      <div class="slide-inner">
        <div style="width:100%;height:100%;background:${art.bg};"></div>
        <div class="slide-overlay"></div>
      </div>
    `;
    /* 카드 클릭 시 해당 방향으로 슬라이드 */
    slide.addEventListener('click', () => {
      const d = (i - current + total) % total;
      if (d === 1 || d === 2)                  navigate('next');
      else if (d === total-1 || d === total-2) navigate('prev');
    });
    stage.appendChild(slide);

    /* 도트 생성 */
    const dot = document.createElement('div');
    dot.className = 'dot';
    dot.addEventListener('click', () => goTo(i));
    dotsEl.appendChild(dot);
  });

  /* ============================================================
     포지션 클래스 계산
     current를 기준으로 각 슬라이드의 상대 위치를 반환

     d = 현재 슬라이드와의 거리 (순환)
     d=0: 중앙(active)
     d=1: 오른쪽 1번째(next) / d=total-1: 왼쪽 1번째(prev)
     d=2: 오른쪽 2번째(next2) / d=total-2: 왼쪽 2번째(prev2)
     d=3: 오른쪽 화면 밖(next3) / d=total-3: 왼쪽 화면 밖(prev3)
     나머지: 완전 숨김(hidden)
  ============================================================ */
  function posClass(i, cur) {
    const d = (i - cur + total) % total;
    if (d === 0)         return 'active';
    if (d === 1)         return 'next';
    if (d === total - 1) return 'prev';
    if (d === 2)         return 'next2';
    if (d === total - 2) return 'prev2';
    if (d === 3)         return 'next3';  /* 오른쪽 화면 밖 대기 */
    if (d === total - 3) return 'prev3';  /* 왼쪽 화면 밖 대기 */
    return 'hidden';
  }

  /* ============================================================
     슬라이더 상태 업데이트
     hidden 카드는 transition 없이 순간이동시켜
     화면을 가로질러 이동하는 현상을 방지
  ============================================================ */
  function updateSlider() {
    const slides = Array.from(stage.querySelectorAll('.slide'));
    slides.forEach((s, i) => {
      const cls = posClass(i, current);
      if (cls === 'hidden') {
        s.style.transition = 'none'; /* ★ 순간이동: 화면 가로지름 방지 */
      } else {
        s.style.transition = '';     /* CSS 클래스의 transition 복원 */
      }
      s.className = 'slide ' + cls;
    });
    /* 도트 활성화 업데이트 */
    dotsEl.querySelectorAll('.dot').forEach((d, i) => {
      d.classList.toggle('active', i === current);
    });
  }

  /* ============================================================
     슬라이드 전환
  ============================================================ */
  function navigate(dir) {
    if (isAnimating) return; /* 전환 중 중복 방지 */
    isAnimating = true;
    current = dir === 'next'
      ? (current + 1) % total           /* 오른쪽 → 인덱스 증가 */
      : (current - 1 + total) % total;  /* 왼쪽 → 인덱스 감소 (음수 방지) */
    updateSlider();
    setTimeout(() => { isAnimating = false; }, 760); /* transition 시간(0.75s)과 맞춤 */
  }

  /* 특정 인덱스로 바로 이동 (도트 클릭용) */
  function goTo(i) {
    if (isAnimating || i === current) return;
    isAnimating = true;
    current = i;
    updateSlider();
    setTimeout(() => { isAnimating = false; }, 760);
  }

  /* ============================================================
     이벤트 바인딩
  ============================================================ */
  document.getElementById('prevBtn').addEventListener('click', () => navigate('prev'));
  document.getElementById('nextBtn').addEventListener('click', () => navigate('next'));

  /* 키보드 좌우 방향키 */
  document.addEventListener('keydown', e => {
    if (e.key === 'ArrowLeft')  navigate('prev');
    if (e.key === 'ArrowRight') navigate('next');
  });

  /* 터치 스와이프 */
  let startX = 0, mdown = false;
  document.addEventListener('touchstart', e => { startX = e.touches[0].clientX; }, {passive:true});
  document.addEventListener('touchend', e => {
    const d = startX - e.changedTouches[0].clientX;
    if (Math.abs(d) > 40) navigate(d > 0 ? 'next' : 'prev'); /* 40px 이상 스와이프 */
  });

  /* 마우스 드래그 */
  document.addEventListener('mousedown', e => { startX = e.clientX; mdown = true; });
  document.addEventListener('mouseup', e => {
    if (!mdown) return;
    mdown = false;
    const d = startX - e.clientX;
    if (Math.abs(d) > 50) navigate(d > 0 ? 'next' : 'prev'); /* 50px 이상 드래그 */
  });

  /* 자동 재생 (4초 간격) — 클릭 시 타이머 리셋 */
  let timer = setInterval(() => navigate('next'), 4000);
  document.addEventListener('click', () => {
    clearInterval(timer);
    timer = setInterval(() => navigate('next'), 4000);
  });

  /* 초기 렌더링 */
  updateSlider();
</script>
</body>
</html>
